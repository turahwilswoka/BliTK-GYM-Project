{
	frankenphp
	order php_server before file_server
}

:{$PORT:80} {
	root * /var/www/html/public
	encode zstd br gzip

	# Forward the HTTPS scheme header so Laravel knows the request came
	# through Railway's HTTPS proxy — prevents "insecure form" warnings.
	header_up X-Forwarded-Proto https

	php_server {
		resolve_root_symlink
	}
}
